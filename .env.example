# BiletCell — Ortam Değişkenleri (Environment Variables)
# Bu dosyayı kopyalayıp .env olarak kaydedin
# Copy this file and save as .env

# API Sunucusu Portu (varsayılan: 8080)
PORT=8080

# JWT Gizli Anahtarı (güçlü bir değer seçin — production için zorunlu)
SESSION_SECRET=biletcell_dev_secret_2026

# Veritabanı Dosya Yolu (varsayılan: proje kök dizini/biletcell.db)
# DATABASE_PATH=./biletcell.db
